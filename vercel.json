{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/client/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/client/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}
